# PIXTRACE local face worker — copy to `.env` and fill in.
# These are the SAME values used by your Next.js app (Vercel env / .env.local).
# Point at DEV or PROD depending on which database you want the laptop to serve.

# ── Supabase (service_role — full DB access; keep secret, never commit) ──
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# ── Cloudflare R2 (same creds as the web app) ──
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=xxxxxxxxxxxx
R2_SECRET_ACCESS_KEY=xxxxxxxxxxxx
R2_BUCKET_NAME=pixtrace-media-dev

# ── Tuning (optional — defaults shown) ──
# SEARCH_POLL_INTERVAL=3      # how often to check for new selfie searches (seconds)
# GALLERY_POLL_INTERVAL=15    # how often to check for new gallery photos (seconds)
# GALLERY_BATCH_SIZE=50       # photos claimed per gallery round
# SEARCH_BATCH_SIZE=5         # selfies claimed per search round
# WORKER_FORCE_CPU=0          # set to 1 to force CPU even if a GPU is present

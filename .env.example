# ============================================================
# PIXTRACE Environment Variables
# Copy to .env.local and fill in your values
# See .env.production for prod reference (not committed)
# ============================================================

# Supabase Auth (use DEV project for local development)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Cloudflare R2 (S3-compatible)
R2_ACCOUNT_ID="your-account-id"
R2_ACCESS_KEY_ID="your-access-key"
R2_SECRET_ACCESS_KEY="your-secret-key"
R2_BUCKET_NAME="pixtrace-media-dev"

# Cloudflare Images
CLOUDFLARE_ACCOUNT_HASH="your-account-hash"
CLOUDFLARE_IMAGES_DELIVERY_URL="https://imagedelivery.net/your-hash"

# Application
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Download security (HMAC-signed download tokens)
# Optional: auto-derives from SUPABASE_SERVICE_ROLE_KEY if not set
DOWNLOAD_TOKEN_SECRET="your-random-secret-min-32-chars"

# Face processing trigger auth
FACE_PROCESSING_SECRET="your-face-processing-secret"

# AWS SageMaker (for AI embeddings)
SAGEMAKER_ENDPOINT_URL="https://runtime.sagemaker.us-east-1.amazonaws.com"
SAGEMAKER_ENDPOINT_NAME="arcface-embedding-endpoint"
AWS_ACCESS_KEY_ID="your-aws-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret"

# Razorpay (use TEST keys for development)
RAZORPAY_KEY_ID="rzp_test_xxxxxxxxx"
RAZORPAY_KEY_SECRET="your-razorpay-secret"
RAZORPAY_WEBHOOK_SECRET="your-webhook-secret"
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_xxxxxxxxx"

# Next.js
NODE_ENV="development"

# Face Search (Modal pipeline)
MODAL_EMBED_SELFIE_CPU_URL="https://your-modal-endpoint.modal.run"
MODAL_EMBED_SELFIE_URL="https://your-modal-endpoint.modal.run"
MODAL_PROCESS_GALLERY_URL="https://your-modal-endpoint.modal.run"

# Google Drive Import (Modal pipeline)
GOOGLE_DRIVE_API_KEY="your-google-drive-api-key"
MODAL_DRIVE_IMPORT_URL="https://your-modal-drive-import-endpoint.modal.run"

# Email (Resend - transactional emails)
RESEND_API_KEY="re_xxxxxxxxx"

# Cron Jobs (storage cleanup)
CRON_SECRET="your-random-cron-secret-min-32-chars"

# Sentry (error monitoring)
NEXT_PUBLIC_SENTRY_DSN="https://your-key@o123456.ingest.sentry.io/1234567"
SENTRY_ORG="your-sentry-org"
SENTRY_PROJECT="pixtrace"
SENTRY_AUTH_TOKEN="sntrys_your-auth-token"

# Admin
ADMIN_EMAILS="your-admin@email.com"
